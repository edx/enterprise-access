# Billing Management API Integration Test Configuration
#
# Copy this file to .env and fill in your actual credentials.
# NEVER commit the .env file to version control!
#
# Usage:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your credentials below
#   3. Run tests: python scripts/test_billing_integration.py --all

# =============================================================================
# OAuth JWT Authentication (REQUIRED)
# =============================================================================
# These credentials are used to authenticate API requests via JWT tokens.
# Get these from your OAuth application configuration.

# OAuth application client ID
OAUTH_CLIENT_ID=your_client_id_here

# OAuth application client secret (keep this secret!)
OAUTH_CLIENT_SECRET=your_client_secret_here

# OAuth token endpoint URL
# For local development: http://localhost:18000/oauth2/access_token
# For devstack: http://localhost:18000/oauth2/access_token
OAUTH_TOKEN_URL=http://localhost:18000/oauth2/access_token

# =============================================================================
# API Configuration (REQUIRED)
# =============================================================================

# Base URL for the enterprise-access API
# For local development: http://localhost:18270/api/v1
# For devstack: http://localhost:18270/api/v1
API_BASE_URL=http://localhost:18270/api/v1

# Enterprise customer UUID to use for testing
# This should be an enterprise that has billing configured in your test environment
ENTERPRISE_CUSTOMER_UUID=your-enterprise-uuid-here

# =============================================================================
# Stripe Configuration (OPTIONAL)
# =============================================================================
# These are optional but useful for verification and debugging.
# Use your Stripe sandbox/test credentials.

# Stripe API key (test/sandbox key starting with sk_test_)
# Used for optional verification of Stripe state
# STRIPE_API_KEY=sk_test_your_key_here

# Stripe customer ID associated with your test enterprise
# Used for debugging and verification
# STRIPE_CUSTOMER_ID=cus_your_customer_id_here

# =============================================================================
# Test User Credentials (OPTIONAL)
# =============================================================================
# Optional test user credentials if needed for certain tests

# TEST_USER_EMAIL=test@example.com
# TEST_USER_PASSWORD=password123

# =============================================================================
# Notes
# =============================================================================
#
# Security Best Practices:
# - Never commit this file with real credentials
# - Use different credentials for dev/staging/prod
# - Rotate credentials regularly
# - Use a secrets manager for production use
#
# Getting OAuth Credentials:
# 1. Create an OAuth application in Django admin
# 2. Set the client type to "Confidential"
# 3. Set authorization grant type to "Client credentials"
# 4. Copy the client ID and secret
#
# Finding Enterprise UUID:
# - Check Django admin under Enterprise Customer
# - Use the /admin/enterprise/ endpoint
# - Check your Stripe customer metadata
